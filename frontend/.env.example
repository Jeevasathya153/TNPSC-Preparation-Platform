# Frontend Client Configuration — Example
# ============================================================
# Copy this file to .env for local development.
#
# LOCAL DEVELOPMENT:
#   VITE_API_BASE_URL=/api
#   The Vite dev server proxies /api → http://localhost:8080
#   (configured in vite.config.js)
#
# PRODUCTION (Vercel):
#   Do NOT create .env.production — it blocks Vercel from
#   injecting the real value at build time.
#
#   Instead, set in Vercel dashboard:
#   Project Settings → Environment Variables → Production
#     VITE_API_BASE_URL = https://<your-railway-project>.up.railway.app/api
#     VITE_API_URL      = https://<your-railway-project>.up.railway.app/api
# ============================================================

# Backend API base URL (local dev: /api, production: set via Vercel dashboard)
VITE_API_BASE_URL=
VITE_API_URL=

# App Metadata
VITE_APP_NAME=
VITE_APP_VERSION=

# API requests timeout in milliseconds (e.g. 10000 = 10s)
VITE_API_TIMEOUT=
